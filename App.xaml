<Application x:Class="CommandWizard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CommandWizard"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dark theme, LightBlue primary (more blue than Teal) -->
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="LightBlue" SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Brand brushes — used in inline layout (Borders, placeholders, etc.)
                MD handles all control implicit styles, so we don't redefine Button/TextBox/etc.
            -->
            <SolidColorBrush x:Key="PrimaryBrush"         Color="#0D89C8"/>
            <SolidColorBrush x:Key="PrimaryDarkBrush"     Color="#096A9B"/>
            <SolidColorBrush x:Key="AccentBrush"          Color="#29B6F6"/>
            <SolidColorBrush x:Key="BackgroundBrush"      Color="#1C1B1F"/>
            <SolidColorBrush x:Key="SurfaceBrush"         Color="#2B2930"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#322F37"/>
            <SolidColorBrush x:Key="BorderBrush"          Color="#5C5966"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#E6E1E5"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#CAC4D0"/>
            <SolidColorBrush x:Key="TextMutedBrush"       Color="#938F99"/>

            <!-- Primary action button: filled teal -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <!-- Muted/secondary button: text style, no background -->
            <Style x:Key="MutedButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
